# PostgreSQL
POSTGRES_USER=exalink
POSTGRES_PASSWORD=exalink_pass
POSTGRES_DB=exalink_campo

# JWT
SECRET_KEY=CHANGE_ME_SUPER_SECRET_KEY_32CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Redis
REDIS_URL=redis://redis:6379/0

# URLs
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
VITE_API_URL=http://localhost:8000/api/v1

# Notificaciones
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@exalink.com

# LoRaWAN Listener
LORA_LISTEN_PORT=6666
LORA_AUTH_PASSWORD=abc1234
LORA_MAX_PACKETS=500
LORA_DB_PATH=/app/lora_db/lora.db

# Entorno
ENVIRONMENT=development
DEBUG=true
